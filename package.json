{
  "name": "@local/metastellar",
  "version": "0.1.0",
  "description": "MetaStellar bridges MetaMask users into Stellar and Soroban dApps with secure wallet interoperability, familiar Web3 UX, and signed Stellar action intents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "stellar",
    "soroban",
    "metastellar",
    "metamask",
    "connector",
    "wallet",
    "eip-712"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gchacon011/metastellar.git"
  },
  "bugs": {
    "url": "https://github.com/gchacon011/metastellar/issues"
  },
  "homepage": "https://github.com/gchacon011/metastellar#readme",
  "peerDependencies": {
    "@stellar/stellar-sdk": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
